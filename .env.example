# DraftRelay local source-server defaults.
HOST=127.0.0.1
PORT=3939
DATA_DIR=./data
PUBLIC_BASE_URL=http://127.0.0.1:3939

# Local v0.2 compatibility variables retained by the `draftrelay`/`cutline` CLI.
# CUTLINE_HOME=./portable-draftrelay
# CUTLINE_DATA_DIR=./data
# CUTLINE_POLICY_FILE=./.cutline.yml
# CUTLINE_URL=http://127.0.0.1:3939
# AI_DUMP_URL=http://127.0.0.1:3939

# Hosted mode
#
# Use a separate environment/secret set rather than enabling this block beside
# the local values above. NODE_ENV=production requires HTTPS, Redis, Better Auth,
# Stripe, Resend, EMAIL_FROM, and both Turnstile keys. Production PostgreSQL
# and Redis URLs must require TLS. Never commit a populated production file.

# NODE_ENV=development
# HOST=0.0.0.0
# PORT=3941
# APP_NAME=DraftRelay
# APP_URL=http://localhost:3941
# Production requires real operator details for the generated legal pages.
# LEGAL_NAME=Example Company LLC
# LEGAL_EMAIL=legal@example.com
# LEGAL_JURISDICTION=Dubai, United Arab Emirates
# LEGAL_EFFECTIVE_DATE=2026-07-10

# Use a non-owner, non-superuser runtime role in production. The migration runner
# should receive a separate migration-owner URL only while migrations run.
# DATABASE_URL=postgres://draftrelay_app:...@db.example.com/draftrelay?sslmode=verify-full
# REDIS_URL=rediss://cache.example.com:6380

# Operational commands only; do not give this owner URL to the running app.
# `pnpm db:migrate` prefers MIGRATION_DATABASE_URL and falls back to DATABASE_URL
# for local development. `pnpm db:grant-runtime` requires the owner URL below.
# MIGRATION_DATABASE_URL=postgres://draftrelay_owner:...@localhost:5432/draftrelay
# RUNTIME_DATABASE_ROLE=draftrelay_app

# Minimum 32 characters. Generate a unique value with: openssl rand -base64 32
# BETTER_AUTH_SECRET=development-only-change-before-shared-use

# Exact comma-separated origins and actual trusted proxy IPs/CIDRs only.
# TRUSTED_ORIGINS=https://preview.example.com
# TRUSTED_PROXY_IPS=127.0.0.1

# Stripe test-mode placeholders. Production uses separate live credentials.
# Create recurring $1/month and $10/year Prices with these lookup keys.
# STRIPE_SECRET_KEY=sk_test_...
# STRIPE_WEBHOOK_SECRET=whsec_...
# STRIPE_PRO_MONTHLY_LOOKUP_KEY=draftrelay_pro_monthly
# STRIPE_PRO_YEARLY_LOOKUP_KEY=draftrelay_pro_yearly

# Production email verification/reset. EMAIL_FROM accepts either a verified
# address or display-name form such as "DraftRelay <hello@example.com>".
# RESEND_API_KEY=re_...
# EMAIL_FROM=hello@example.com

# Optional logging and plan-limit overrides.
# LOG_LEVEL=info
# FREE_MONTHLY_SAVES=500
# FREE_DAILY_SAVES=50
# FREE_STORED_ITEMS=2000
# FREE_STORAGE_BYTES=10485760
# PAID_MONTHLY_SAVES=10000
# PAID_DAILY_SAVES=1000
# PAID_STORED_ITEMS=50000
# PAID_STORAGE_BYTES=262144000

# Cloudflare Turnstile challenge for email signup. Both keys are required in
# production; the server verifies the token and hostname before creating a user.
# TURNSTILE_SECRET_KEY=...
# TURNSTILE_SITE_KEY=...
